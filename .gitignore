# Environment files
.env

# Pi-hole runtime data
pihole-data/etc-pihole/*
!pihole-data/etc-pihole/.gitkeep
pihole-data/etc-dnsmasq.d/*
!pihole-data/etc-dnsmasq.d/.gitkeep

# dnscrypt-proxy downloads its resolver list into config/ at runtime
config/public-resolvers.md
config/public-resolvers.md.minisig

