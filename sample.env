# Timezone for the containers (e.g. America/Chicago, America/New_York, Europe/London)
TZ=America/Chicago

# Pi-hole web interface password
WEBPASSWORD=changeme

# Loopback alias IP that Pi-hole binds DNS and the web UI to.
# mDNSResponder owns 0.0.0.0:53 on macOS; using a loopback alias avoids the conflict.
# Run scripts/setup.sh to create this alias automatically.
LOOPBACK_IP=127.0.0.2
